# ════════════════════════════════════════════
# PROMETHEUS UNBOUND — Environment Config
# Copy this file to .env and fill your values
# NEVER commit .env to git
# ════════════════════════════════════════════

# ── Database ──────────────────────────────
# LOCAL (default — works with docker-compose)
DB_URL=postgres://tsadmin:tspassword@localhost:5432/prometheusdb

# CLOUD (your TimescaleDB trial — uncomment to use)
# DB_URL=postgres://your_user:your_pass@your_cloud_host:5432/your_db

# ── Kafka ──────────────────────────────────
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_TOPIC=metrics
KAFKA_GROUP_ID=prometheus-consumer

# ── Ghostgres (AI layer) ───────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Grafana ────────────────────────────────
GRAFANA_ADMIN_PASSWORD=admin

# ── App config ─────────────────────────────
TENANTS=tenant_alpha,tenant_beta,tenant_gamma
ANOMALY_ZSCORE_THRESHOLD=3.0
INGESTION_INTERVAL_SECONDS=1
